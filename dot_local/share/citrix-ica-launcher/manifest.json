{
  "manifest_version": 3,
  "name": "Citrix ICA Launcher",
  "version": "1.0",
  "description": "Detects Citrix ICA launch files in network responses and hands them to a native host to launch wfica.",
  "key": "",
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["webRequest", "downloads", "nativeMessaging"],
  "host_permissions": ["<all_urls>"]
}
